<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🦉 SovaTest"
            android:textColor="#00FF88"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="На Урок + Всеосвіта"
            android:textColor="#888888"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/statusOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:padding="12dp"
            android:background="#1A1A25"
            android:text="Оверлей: —"
            android:textColor="#C0C0C0"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/statusA11y"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:background="#1A1A25"
            android:text="Accessibility: —"
            android:textColor="#C0C0C0"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/btnOverlayPerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="1. Дозвіл на поверх вікон"
            android:backgroundTint="#333344"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnA11yPerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="2. Accessibility (для АВТО)"
            android:backgroundTint="#333344"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="▶ ПУСК"
            android:backgroundTint="#00AA55"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Після ПУСК — відкривай Chrome і заходь на тест.\n\nРежим АВТО — бот сам тисне відповіді.\nРежим ПІДКАЗКА — обводить відповідь, тиснеш сам."
            android:textColor="#888888"
            android:textSize="12sp"/>
    </LinearLayout>
</ScrollView>
